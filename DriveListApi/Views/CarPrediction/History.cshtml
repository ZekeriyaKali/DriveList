@model List<PredictionHistory>
@{
    ViewData["Title"] = "Tahmin Geçmişim";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold gradient-text">📜 Tahmin Geçmişim</h2>
        <p class="text-muted">Daha önce yaptığınız tüm tahminleri buradan görüntüleyebilirsiniz.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm rounded-4 p-4">
            Henüz tahmin geçmişiniz bulunmamaktadır. 🚗💨
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card shadow-lg border-0 rounded-4 h-100 hover-card">
                        <!-- Kart Başlık -->
                        <div class="card-header text-white rounded-top-4 gradient-header">
                            <h5 class="mb-0 fw-bold">@item.Brand @item.Model</h5>
                            <small class="text-light">@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                        </div>

                        <!-- Kart Gövde -->
                        <div class="card-body">
                            <ul class="list-group list-group-flush mb-3 rounded-3 overflow-hidden">
                                <li class="list-group-item"><strong>📅 Yıl:</strong> @item.Year</li>
                                <li class="list-group-item"><strong>📍 Kilometre:</strong> @String.Format("{0:N0}", item.Km) km</li>
                                <li class="list-group-item"><strong>⚙️ Vites:</strong> @item.GearType</li>
                                <li class="list-group-item"><strong>⛽ Yakıt:</strong> @item.FuelType</li>
                                <li class="list-group-item"><strong>🏙️ Şehir:</strong> @item.City</li>
                            </ul>
                            <div class="alert alert-success text-center shadow-sm fs-5 rounded-3 mb-0">
                                Tahmini Fiyat:
                                <span class="fw-bold text-dark">
                                    @String.Format("{0:N0}", item.PredictedPrice) ₺
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #f6f9fc, #e9ecef);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .gradient-header {
            background: linear-gradient(90deg, #0d6efd, #20c997);
        }

        .gradient-text {
            background: linear-gradient(90deg, #0d6efd, #20c997);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hover-card {
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .hover-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.15);
            }

        .list-group-item {
            font-size: 0.95rem;
        }
    </style>
}
