@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="width: 420px;">
        <!-- Başlık -->
        <div class="card-header text-white text-center py-4 rounded-top-4 gradient-header">
            <h3 class="mb-0 fw-bold">🔑 Giriş Yap</h3>
            <small class="text-light">Hesabınıza erişmek için giriş yapın</small>
        </div>

        <div class="card-body">
            <form asp-action="Login" method="post">
                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
                {
                    <div asp-validation-summary="All" class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span>Lütfen formu kontrol edin.</span>
                    </div>
                }

                <!-- Kullanıcı Adı -->
                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold">
                        <i class="bi bi-person-fill me-1"></i> Kullanıcı Adı
                    </label>
                    <input asp-for="Username" class="form-control rounded-3" placeholder="Kullanıcı adınızı girin" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <!-- Şifre -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">
                        <i class="bi bi-lock-fill me-1"></i> Şifre
                    </label>
                    <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Beni Hatırla -->
                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Beni hatırla</label>
                </div>

                <!-- Giriş Yap -->
                <button type="submit" class="btn btn-gradient w-100 shadow-sm">
                    🚀 Giriş Yap
                </button>
            </form>

            <!-- Parola unutma -->
            <div class="text-center mt-3">
                <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none">
                    Parolamı unuttum?
                </a>
            </div>

            <!-- Google ile giriş -->
            <div class="text-center mt-3">
                <form asp-action="ExternalLogin" asp-route-provider="Google" method="post">
                    <button type="submit" class="btn btn-outline-danger w-100 shadow-sm">
                        <i class="bi bi-google"></i> Google ile Giriş Yap
                    </button>
                </form>
            </div>

            <!-- Kayıt Ol -->
            <p class="text-center mt-3 mb-0">
                Hesabın yok mu?
                <a asp-controller="Account" asp-action="Register" class="fw-bold text-decoration-none text-primary">
                    Kayıt Ol
                </a>
            </p>
        </div>
    </div>
</div>

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #f6f9fc, #e9ecef);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .gradient-header {
            background: linear-gradient(90deg, #0d6efd, #20c997);
        }

        .btn-gradient {
            background: linear-gradient(90deg, #0d6efd, #20c997);
            color: #fff;
            font-weight: 600;
            border: none;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
            }

        .field-validation-error {
            color: #dc3545;
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }
    </style>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
