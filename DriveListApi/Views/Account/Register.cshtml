@model RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 rounded-4 p-4 w-100" style="max-width: 450px;">
        <!-- Başlık -->
        <div class="card-header text-white text-center py-4 rounded-top-4 gradient-header">
            <h3 class="mb-0 fw-bold">📝 Kayıt Ol</h3>
            <small class="text-light">Hesap oluşturmak için bilgilerinizi girin</small>
        </div>

        <div class="card-body">
            <form asp-action="Register" method="post">
                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
                {
                    <div asp-validation-summary="All" class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span>Lütfen formu kontrol edin.</span>
                    </div>
                }

                <!-- Kullanıcı Adı -->
                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold">
                        <i class="bi bi-person-fill me-1"></i> Kullanıcı Adı
                    </label>
                    <input asp-for="Username" class="form-control rounded-3" placeholder="Kullanıcı adınızı girin" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">
                        <i class="bi bi-envelope-fill me-1"></i> E-posta
                    </label>
                    <input asp-for="Email" type="email" class="form-control rounded-3" placeholder="ornek@mail.com" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Şifre -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">
                        <i class="bi bi-lock-fill me-1"></i> Şifre
                    </label>
                    <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Şifre Onay -->
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold">
                        <i class="bi bi-shield-lock-fill me-1"></i> Şifre Onayla
                    </label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <!-- reCAPTCHA -->
                <div class="g-recaptcha mb-3" data-sitekey="YOUR_SITE_KEY"></div>

                <!-- Kayıt Ol -->
                <button type="submit" class="btn btn-gradient w-100 shadow-sm">
                    🚀 Kayıt Ol
                </button>
            </form>

            <!-- Giriş linki -->
            <p class="text-center mt-3 mb-0">
                Zaten hesabın var mı?
                <a asp-controller="Account" asp-action="Login" class="fw-bold text-decoration-none text-primary">
                    Giriş Yap
                </a>
            </p>
        </div>
    </div>
</div>

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #f6f9fc, #e9ecef);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .gradient-header {
            background: linear-gradient(90deg, #0d6efd, #20c997);
        }

        .btn-gradient {
            background: linear-gradient(90deg, #0d6efd, #20c997);
            color: #fff;
            font-weight: 600;
            border: none;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
            }

        .field-validation-error {
            color: #dc3545;
            font-size: 0.85rem;
            margin-top: 4px;
            display: block;
        }
    </style>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
}